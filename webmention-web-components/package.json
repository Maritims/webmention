{
    "name": "webmention-web-components",
    "version": "0.0.1-alpha.6",
    "description": "Web components for presenting webmentions.",
    "main": "./dist/webmention-web-components.js",
    "type": "module",
    "files": [
        "dist/webmention-web-components.js",
        "src/LICENSE",
        "src/README.md"
    ],
    "exports": {
        ".": "./src/webmention-web-components.js",
        "./list": "./src/webmention-list.js"
    },
    "keywords": [
        "webmention",
        "indieweb",
        "web-components",
        "custom-elements"
    ],
    "author": {
        "name": "Martin Severin Steffensen",
        "email": "martin.severin.steffensen@proton.me",
        "url": "https://clueless.no/"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Maritims/webmention.git"
    },
    "scripts": {
        "build": "esbuild src/webmention-web-components.js --bundle --outfile=dist/webmention-web-components.js --minify --banner:js=\"/* ${npm_package_name} v${npm_package_version} */\""
    },
    "devDependencies": {
        "esbuild": "^0.27.3"
    }
}
